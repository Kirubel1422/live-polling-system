{
  "name": "live-polling-backend",
  "version": "1.0.0",
  "description": "Backend for the Live Polling System",
  "main": "dist/app.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/app.js",
    "dev": "nodemon -r tsconfig-paths/register src/app.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:templates": "ts-node -r tsconfig-paths/register src/scripts/seed-templates.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
